[Unit]
Description=Cognitora Router (OpenAI gateway + KV-aware orchestrator)
Documentation=https://github.com/cognitora/cognitora
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
User=cognitora
Group=cognitora
EnvironmentFile=-/etc/cognitora/cgn-router.env
ExecStart=/usr/local/bin/cgn-router --config /etc/cognitora/cognitora.toml
Restart=on-failure
RestartSec=2s
LimitNOFILE=1048576
LimitNPROC=infinity
LimitCORE=infinity
TasksMax=infinity
TimeoutStopSec=30s
KillMode=mixed

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=no            # need /dev/nvidia* exposure when colocated
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
ReadWritePaths=/var/lib/cognitora /var/log/cognitora

[Install]
WantedBy=multi-user.target
